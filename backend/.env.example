APP_NAME=MetaNest API
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=20
UPLOAD_DIR=uploads
DATA_DIR=data
# Optional. When omitted, MetaNest uses backend/data/projects.json.
MONGODB_URI=
MONGODB_DATABASE=metanest
# Optional AI model artifacts. Leave empty for OpenCV/heuristic MVP mode.
YOLO_OPENING_MODEL_PATH=
UNET_ROOM_MODEL_PATH=
